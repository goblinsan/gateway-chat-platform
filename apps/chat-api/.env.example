NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# LM Studio instances
LM_STUDIO_A_BASE_URL=http://localhost:1234
LM_STUDIO_B_BASE_URL=http://192.168.1.100:1234

# Paid provider API keys (leave blank if not using)
