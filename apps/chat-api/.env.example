NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# LM Studio instances
LM_STUDIO_A_BASE_URL=http://localhost:1234
LM_STUDIO_B_BASE_URL=http://192.168.1.100:1234

# Paid provider API keys (leave blank if not using)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Cloudflare Access (production only)
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# Build metadata (injected by CI)
BUILD_VERSION=0.0.0
BUILD_COMMIT=unknown

# APNs (Apple Push Notification service)
# Obtain Team ID, Key ID, and Bundle ID from developer.apple.com
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
# Path to the .p8 private key file downloaded from developer.apple.com
APNS_PRIVATE_KEY_PATH=
# OR supply the private key as a base64-encoded string (alternative to path)
APNS_PRIVATE_KEY_BASE64=
# Set to true to use the APNs sandbox (development) endpoint
APNS_SANDBOX=false
