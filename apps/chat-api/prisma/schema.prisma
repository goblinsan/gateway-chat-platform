generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Conversation {
  id           String    @id @default(uuid())
  userId       String    @default("me")
  agentId      String
  title        String
  defaultModel String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  usageLogs    UsageLog[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  model          String?
  provider       String?
  createdAt      DateTime     @default(now())
}

model UsageLog {
  id               String        @id @default(uuid())
  userId           String        @default("me")
  conversationId   String?
  conversation     Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  agentId          String
  provider         String
  model            String
  promptTokens     Int           @default(0)
  completionTokens Int           @default(0)
  totalTokens      Int           @default(0)
  estimatedCostUsd Float         @default(0)
  latencyMs        Int
  createdAt        DateTime      @default(now())
}

model Agent {
  id              String   @id
  name            String
  icon            String   @default("🤖")
  color           String   @default("#6366f1")
  providerName    String
  model           String
  costClass       String   @default("free")
  systemPrompt    String?
  temperature     Float?
  maxTokens       Int?
  enableReasoning Boolean  @default(false)
  featureFlags    String?  // JSON string
  routingPolicy   String?  // JSON string
  endpointConfig  String?  // JSON string
  contextSources  String?  // JSON string
  executionMode   String   @default("direct_provider")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ModelQuota {
  id          String   @id @default(uuid())
  userId      String   @default("*")
  model       String
  windowHours Int      @default(24)
  maxTokens   Int?
  maxRequests Int?
  maxCostUsd  Float?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, model])
}

model UserPersona {
  id              String   @id @default(uuid())
  userId          String
  name            String
  description     String?
  systemPrompt    String?
  icon            String   @default("🧑")
  color           String   @default("#8b5cf6")
  providerName    String   @default("auto")
  model           String   @default("auto")
  temperature     Float?
  maxTokens       Int?
  enableReasoning Boolean  @default(false)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model MobileDevice {
  id         String   @id @default(uuid())
  userId     String
  platform   String
  tokenHash  String
  tokenLast4 String
  deviceName String?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  pushAttempts PushAttempt[]

  @@unique([userId, platform, tokenHash])
  @@index([userId, platform])
}

model PushAttempt {
  id           String   @id @default(uuid())
  deviceId     String
  device       MobileDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  provider     String   @default("apns")
  alertId      String?
  status       String   // "success" | "error"
  errorCode    String?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([deviceId])
}

model Alert {
  id              String    @id @default(uuid())
  userId          String
  title           String
  body            String?
  severity        String    @default("info")  // "critical" | "high" | "medium" | "low" | "info"
  source          String
  sourceNode      String?
  sourceService   String?
  status          String    @default("open")  // "open" | "acknowledged" | "resolved"
  relatedThreadId String?
  relatedActionId String?
  metadataJson    String?
  createdAt       DateTime  @default(now())
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?

  @@index([userId, status])
  @@index([userId, createdAt])
}

model ActionApproval {
  id                String    @id @default(uuid())
  userId            String
  title             String
  description       String?
  riskLevel         String    @default("medium")  // "critical" | "high" | "medium" | "low"
  actionType        String
  targetNode        String?
  targetService     String?
  proposedByAgentId String?
  status            String    @default("pending")  // "pending" | "approved" | "denied" | "expired"
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  decidedAt         DateTime?
  decidedBy         String?
  metadataJson      String?

  @@index([userId, status])
  @@index([userId, createdAt])
}
